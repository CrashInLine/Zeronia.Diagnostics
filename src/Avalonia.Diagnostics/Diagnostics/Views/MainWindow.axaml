<u:UrsaWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Avalonia.Diagnostics.Views;assembly=Avalonia.Diagnostics"
        xmlns:viewModels="clr-namespace:Avalonia.Diagnostics.ViewModels;assembly=Avalonia.Diagnostics"
        xmlns:diagnostics="clr-namespace:Avalonia.Diagnostics;assembly=Avalonia.Diagnostics"
        xmlns:semi="https://irihi.tech/semi"
        xmlns:u="https://irihi.tech/ursa"
        Title="Avalonia DevTools"
        x:Class="Avalonia.Diagnostics.Views.MainWindow"
        x:DataType="viewModels:MainViewModel">
  <u:UrsaWindow.DataTemplates>
    <diagnostics:ViewLocator/>
  </u:UrsaWindow.DataTemplates>

  <u:UrsaWindow.Styles>
      <SimpleTheme />
      <semi:SemiTheme />
      <semi:UrsaSemiTheme />
      <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Simple.xaml"/>
      <StyleInclude Source="avares://Avalonia.Diagnostics/Diagnostics/Controls/ThicknessEditor.axaml" />
      <StyleInclude Source="avares://Avalonia.Diagnostics/Diagnostics/Controls/FilterTextBox.axaml" />
      <StyleInclude Source="avares://Avalonia.Diagnostics/Diagnostics/Controls/BrushEditor.axaml" />
      <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Simple/Simple.xaml" />
  </u:UrsaWindow.Styles>
  <views:MainView/>
</u:UrsaWindow>
